{
  "version": 2,
  "builds": [
    {
      "src": "certifacts/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 15 }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "certifacts/wsgi.py"
    }
  ]
}
